<%- include("../partials/header") %>

<main class="auth-page">
  <section class="auth-panel">
    <p class="eyebrow">Welcome back</p>
    <h1>Login</h1>
    <p>Access your dashboard or management tools based on your role.</p>

    <% if (errors.length) { %>
      <div class="form-errors">
        <% errors.forEach((error) => { %>
          <p><%= error.msg %></p>
        <% }) %>
      </div>
    <% } %>

    <form action="/login" method="post" class="stacked-form">
      <label>
        Email
        <input type="email" name="email" value="<%= formData.email ?? '' %>" required>
      </label>
      <label>
        Password
        <input type="password" name="password" minlength="8" required>
      </label>
      <button class="primary-button" type="submit">Login</button>
    </form>
    <p class="form-note">Need an account? <a href="/register">Create one</a></p>
  </section>
</main>

<%- include("../partials/footer") %>
