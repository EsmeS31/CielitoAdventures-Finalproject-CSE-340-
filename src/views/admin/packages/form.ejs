<%- include("../../partials/header") %>

<main class="auth-page">
  <section class="auth-panel">
    <p class="eyebrow">Admin content management</p>
    <h1><%= title %></h1>

    <% if (errors.length) { %>
      <div class="form-errors">
        <% errors.forEach((error) => { %>
          <p><%= error.msg %></p>
        <% }) %>
      </div>
    <% } %>

    <form class="stacked-form" action="<%= action %>" method="post">
      <label>
        Destination
        <select name="destinationId">
          <option value="">Unassigned</option>
          <% destinations.forEach((destination) => { %>
            <option value="<%= destination.id %>" <%= String(formData.destinationId) === String(destination.id) ? "selected" : "" %>>
              <%= destination.name %>, <%= destination.region %>
            </option>
          <% }) %>
        </select>
      </label>
      <label>Title<input name="title" value="<%= formData.title %>" required></label>
      <label>Key Highlights<textarea name="keyHighlights" rows="3" required><%= formData.keyHighlights %></textarea></label>
      <div class="form-grid">
        <label>Category<input name="category" value="<%= formData.category %>" required></label>
        <label>Duration Days<input type="number" name="durationDays" min="1" value="<%= formData.durationDays %>" required></label>
      </div>
      <div class="form-grid">
        <label>Accommodation<input name="accommodation" value="<%= formData.accommodation %>" required></label>
        <label>Transportation<input name="transportation" value="<%= formData.transportation %>" required></label>
      </div>
      <div class="form-grid">
        <label>Price<input type="number" step="0.01" name="price" min="0" value="<%= formData.price %>" required></label>
        <label>
          Status
          <select name="status">
            <option value="draft" <%= formData.status === "draft" ? "selected" : "" %>>Draft</option>
            <option value="active" <%= formData.status === "active" ? "selected" : "" %>>Active</option>
            <option value="archived" <%= formData.status === "archived" ? "selected" : "" %>>Archived</option>
          </select>
        </label>
      </div>
      <label>Description<textarea name="description" rows="6" required><%= formData.description %></textarea></label>
      <button class="primary-button" type="submit"><%= submitLabel %></button>
    </form>
  </section>
</main>

<%- include("../../partials/footer") %>
